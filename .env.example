# JobSpy MCP Server — environment variable reference
# Copy this file to .env for local development. Never commit .env.

# Server binding
JOBSPY_HOST=0.0.0.0
JOBSPY_PORT=9423

# Set to 1 to enable the HTTP/SSE transport (in addition to stdio)
ENABLE_SSE=1

# Docker image name (used by build/push scripts)
JOBSPY_DOCKER_IMAGE=jobspy

# CORS — comma-separated list of allowed origins for the SSE/API endpoints.
# Leave empty to block all cross-origin requests (recommended for production).
# Example: CORS_ORIGINS=https://myapp.example.com,https://dashboard.example.com
CORS_ORIGINS=

# Log level: error | warn | info | debug
LOG_LEVEL=info
